<!DOCTYPE suite SYSTEM "cmdlinetester.dtd">

<suite id="Liberty JFR Tests" timeout="6000">
	<!-- Cleanup: Remove any existing Liberty server from previous runs. -->
	<test id="Cleanup existing Liberty test server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyServerControl $LIBERTY_HOME$ remove jfrTestServer</command>
		<output type="success" caseSensitive="yes" regex="no">Server jfrTestServer removed</output>
		<output type="success" caseSensitive="yes" regex="no">does not exist</output>
	</test>

	<!-- Test 1: Create Liberty server (cross-platform). -->
	<test id="Create Liberty test server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyServerControl $LIBERTY_HOME$ create jfrTestServer</command>
		<output type="success" caseSensitive="yes" regex="no">Server jfrTestServer created</output>
		<output type="failure" caseSensitive="yes" regex="no">CWWKE0005E</output>
	</test>

	<!-- Test 2: Configure JVM options for JFR. -->
	<test id="Configure JFR options for Liberty server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyJvmOptions $LIBERTY_HOME$/usr/servers/jfrTestServer/jvm.options -XX:StartFlightRecording=filename=$JFR_FILE$</command>
		<output type="success" caseSensitive="yes" regex="no">JVM options configured</output>
		<output type="failure" caseSensitive="yes" regex="no">Exception</output>
	</test>

	<!-- Test 3: Start Liberty with JFR enabled (cross-platform) - approx 10 seconds. -->
	<test id="Start Liberty server with JFR recording">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyServerControl $LIBERTY_HOME$ start jfrTestServer</command>
		<output type="required" caseSensitive="yes" regex="no">Server jfrTestServer started</output>
		<output type="success" caseSensitive="yes" regex="no">Server jfrTestServer started</output>
		<output type="failure" caseSensitive="yes" regex="no">CWWKE0701E</output>
	</test>

	<!-- Test 4: Run workload against Liberty - approx 100 seconds. -->
	<test id="Execute workload against Liberty server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyWorkload http://localhost:9080 100</command>
		<output type="success" caseSensitive="yes" regex="no">Workload complete</output>
		<output type="failure" caseSensitive="yes" regex="no">Connection refused</output>
		<output type="failure" caseSensitive="yes" regex="no">Exception</output>
	</test>

	<!-- Test 5: Stop Liberty server (cross-platform) - approx 5 seconds. -->
	<test id="Stop Liberty server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyServerControl $LIBERTY_HOME$ stop jfrTestServer</command>
		<output type="success" caseSensitive="yes" regex="no">Server jfrTestServer stopped</output>
		<output type="failure" caseSensitive="yes" regex="no">CWWKE0006E</output>
	</test>

	<!-- Test 6: Verify JFR recording was created - approx 30 seconds. -->
	<test id="Verify JFR summary">
		<command>$JFR_EXE$ summary $JFR_FILE$</command>
		<output type="required" caseSensitive="yes" regex="no">Version: 2.1</output>
		<output type="required" caseSensitive="yes" regex="no">jdk.ExecutionSample</output>
		<output type="success" caseSensitive="yes" regex="no">jdk.CPULoad</output>
		<output type="success" caseSensitive="yes" regex="no">jdk.JavaThreadStatistics</output>
		<output type="failure" caseSensitive="yes" regex="no">jfr summary: could not read recording</output>
	</test>

	<!-- Test 7: Verify execution samples in JFR recording - approx 30 seconds. -->
	<test id="Verify JFR execution samples">
		<command>$JFR_EXE$ print --xml --events "ExecutionSample" --stack-depth 1 $JFR_FILE$</command>
		<output type="required" caseSensitive="yes" regex="no">http://www.w3.org/2001/XMLSchema-instance</output>
		<output type="required" caseSensitive="yes" regex="no">jdk.ExecutionSample</output>
		<output type="required" caseSensitive="yes" regex="no">sampledThread</output>
		<output type="success" caseSensitive="yes" regex="no">STATE_RUNNABLE</output>
		<output type="failure" caseSensitive="yes" regex="no">jfr print: could not read recording</output>
	</test>

	<!-- Test 8: Verify thread events in JFR recording - approx 30 seconds. -->
	<test id="Verify JFR thread start events">
		<command>$JFR_EXE$ print --xml --events "ThreadStart" --stack-depth 1 $JFR_FILE$</command>
		<output type="required" caseSensitive="yes" regex="no">jdk.ThreadStart</output>
		<output type="required" caseSensitive="yes" regex="no">eventThread</output>
		<output type="required" caseSensitive="yes" regex="no">javaName</output>
		<output type="success" caseSensitive="yes" regex="no">javaName</output>
		<output type="failure" caseSensitive="yes" regex="no">jfr print: could not read recording</output>
	</test>

	<!-- Test 9: Verify GC events in JFR recording - approx 30 seconds. -->
	<test id="Verify JFR GC heap configuration">
		<command>$JFR_EXE$ print --xml --events "GCHeapConfiguration" $JFR_FILE$</command>
		<output type="required" caseSensitive="yes" regex="no">http://www.w3.org/2001/XMLSchema-instance</output>
		<output type="success" caseSensitive="yes" regex="no">jdk.GCHeapConfiguration</output>
		<output type="failure" caseSensitive="yes" regex="no">jfr print: could not read recording</output>
	</test>

	<!-- Test 10: Configure JVM options for JFR V2. -->
	<test id="Configure JFR V2 options for Liberty server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyJvmOptions $LIBERTY_HOME$/usr/servers/jfrTestServer/jvm.options -XX:+EnableOpenJ9ExperimentalFlightRecording -XX:StartFlightRecording=filename=$JFR_FILE$</command>
		<output type="success" caseSensitive="yes" regex="no">JVM options configured</output>
		<output type="failure" caseSensitive="yes" regex="no">Exception</output>
	</test>

	<!-- Teardown: Cleanup Liberty server (cross-platform). -->
	<test id="Cleanup Liberty test server">
		<command>$EXE$ -Dibm.java9.forceCommonCleanerShutdown=true -cp $RESJAR$ org.openj9.test.LibertyServerControl $LIBERTY_HOME$ remove jfrTestServer</command>
		<output type="success" caseSensitive="yes" regex="no">Server jfrTestServer removed</output>
		<output type="success" caseSensitive="yes" regex="no">does not exist</output>
	</test>
</suite>
